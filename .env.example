# Onshape API credentials — get yours at https://dev-portal.onshape.com/keys
# These are server-wide defaults; users can still override per-export in the UI.
ONSHAPE_ACCESS_KEY=your_access_key_here
ONSHAPE_SECRET_KEY=your_secret_key_here

# Cloudflare Tunnel token (optional)
# Get from: Cloudflare dashboard → Zero Trust → Networks → Tunnels → Create tunnel
# Leave blank to skip the tunnel container and use quick tunnel manually.
TUNNEL_TOKEN=
